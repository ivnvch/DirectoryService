<?xml version="1.0" encoding="utf-8"?>
<!-- Синхронизируйте с корневым nuget.config. Для Docker нужен этот файл в context ./backend.
     URL: https://nuget.pkg.github.com/<OWNER>/index.json — OWNER = аккаунт GitHub, где опубликованы пакеты. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github" value="https://nuget.pkg.github.com/ivnvch/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="ivnvch.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
