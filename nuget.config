<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github" value="https://nuget.pkg.github.com/ivnvch/index.json" />
  </packageSources>
  <!-- Credentials: add via "dotnet nuget add source" with username and password (do not commit tokens) -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="ivnvch.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>